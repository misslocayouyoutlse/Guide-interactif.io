
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:transparent;color:#1a1a2e}
.wrap{max-width:680px;margin:0 auto;padding:0.5rem}
.scene{background:#f0ede8;border-radius:24px;padding:1.4rem 1.2rem 1.5rem;position:relative;overflow:hidden;border:1.5px solid #e0dbd2}
.deco{position:absolute;border-radius:50%;pointer-events:none}
.deco1{width:240px;height:240px;background:#FFE5D0;top:-70px;right:-50px;opacity:0.55}
