   opts:[{icon:"⚙️",main:"Métal",sub:"Acier, aluminium…",col:"#607D8B"},
         {icon:"🪵",main:"Bois",sub:"MDF, contreplaqué…",col:"#8D6E63"},
         {icon:"🧪",main:"Plastique",sub:"PLA, acrylique…",col:"#9C27B0"}]},
  {eye:"Étape 3 / 6 — Précision",txt:"Quel niveau de précision te faut-il ?",cols:"three",
   opts:[{icon:"📏",main:"Standard",sub:"± 5 mm",col:"#78909C"},
         {icon:"🔍",main:"Bonne",sub:"± 2 mm",col:"#26A69A"},
         {icon:"💎",main:"Excellente",sub:"± 1 mm",col:"#7E57C2"}]},
  {eye:"Étape 4 / 6 — Quantité",txt:"Combien de pièces veux-tu produire ?",cols:"three",
   opts:[{icon:"1️⃣",main:"Une seule",sub:"Prototype unique",col:"#E76F51"},
         {icon:"🔟",main:"Moins de 10",sub:"Petite série",col:"#2A9D8F"},
         {icon:"🏭",main:"Plus de 10",sub:"Grande série",col:"#E9A800"}]},
  {eye:"Étape 5 / 6 — Complexité",txt:"Quelle est la complexité de ta pièce ?",cols:"three",
   opts:[{icon:"🟦",main:"Simple",sub:"Formes droites, basiques",col:"#64B5F6"},
         {icon:"🔷",main:"Moyenne",sub:"Courbes, quelques détails",col:"#F4A261"},
         {icon:"🧩",main:"Complexe",sub:"Géométrie avancée, creux",col:"#E63946"}]},
  {eye:"Étape 6 / 6 — Finition",txt:"Quel niveau de finition veux-tu ?",cols:"three",
   opts:[{icon:"🪨",main:"Brut",sub:"Tel que sorti machine",col:"#8D6E63"},
         {icon:"🪵",main:"Poncé",sub:"Surface lissée, mat",col:"#F4A261"},
         {icon:"✨",main:"Poli miroir",sub:"Surface brillante, fine",col:"#7E57C2"}]},
];

const PROCEDES={
  laser:{
    name:"Découpe laser",col:"#E63946",sub:"Enlèvement de matière par faisceau",
    why:"Ta pièce plate avec un bon niveau de précision correspond parfaitement à la découpe laser. Elle s'applique au métal, bois et plastique avec une grande finesse.",
    cout:"Moyen",coutDetail:"5 – 30 € / pièce",eco:2,ecoDetail:"Énergie élevée, peu de chutes",
    phases:{prep:"15 min",fab:"10 – 30 min",finish:"5 min"},
    scores:{cout:3,temps:4,precision:5,eco:2},
    fichiers:{principaux:["DXF","SVG"],secondaires:["AI","PDF"]},
    logiciels:[
      {nom:"Inkscape",type:"free"},{nom:"LightBurn",type:"payant"},
      {nom:"LaserGRBL",type:"free"},{nom:"Adobe Illustrator",type:"payant"},
    ]
  },
  imp3d:{
    name:"Impression 3D",col:"#2A9D8F",sub:"Ajout de matière couche par couche",
    why:"Pièce en volume, plastique, éventuellement complexe — l'impression 3D est idéale pour le prototypage unique.",
    cout:"Faible",coutDetail:"2 – 15 € / pièce",eco:3,ecoDetail:"Peu de chutes, plastique recyclable",
    phases:{prep:"30 min",fab:"1 – 8 h",finish:"15 min"},
    scores:{cout:4,temps:2,precision:3,eco:3},
    fichiers:{principaux:["STL","3MF"],secondaires:["OBJ","STEP"]},
    logiciels:[
      {nom:"Tinkercad",type:"free"},{nom:"Cura",type:"free"},
      {nom:"Fusion 360",type:"free"},{nom:"PrusaSlicer",type:"free"},
    ]
  },
  cnc:{
    name:"Usinage CNC",col:"#E9A800",sub:"Enlèvement de matière — fraiseuse",
    why:"Pour une pièce en volume avec une bonne précision sur bois ou plastique, la fraiseuse numérique donne d'excellents résultats.",
    cout:"Élevé",coutDetail:"20 – 80 € / pièce",eco:2,ecoDetail:"Chutes importantes, huile de coupe",
    phases:{prep:"45 min",fab:"30 min – 2 h",finish:"20 min"},
    scores:{cout:2,temps:3,precision:4,eco:2},
    fichiers:{principaux:["DXF","STEP"],secondaires:["IGES","G-code"]},
    logiciels:[
      {nom:"Fusion 360",type:"free"},{nom:"FreeCAD",type:"free"},
      {nom:"VCarve",type:"payant"},{nom:"Aspire",type:"payant"},
    ]
  },
  cisaille:{
    name:"Cisaillage / Sciage",col:"#5D9B6A",sub:"Découpe rectiligne par lame",
    why:"Simple, rapide et économique pour des formes droites en grande série sur métal ou bois.",
    cout:"Faible",coutDetail:"1 – 8 € / pièce",eco:4,ecoDetail:"Aucune énergie thermique, peu de déchets",
    phases:{prep:"5 min",fab:"2 – 10 min",finish:"5 min"},
    scores:{cout:5,temps:5,precision:2,eco:4},
    fichiers:{principaux:["DXF","PDF"],secondaires:["Plan papier"]},
    logiciels:[
      {nom:"Inkscape",type:"free"},{nom:"LibreCAD",type:"free"},
      {nom:"AutoCAD LT",type:"payant"},{nom:"QCAD",type:"free"},
    ]
  },
  pliage:{
    name:"Pliage",col:"#9B59B6",sub:"Mise en forme à froid ou à chaud",
    why:"Ta pièce plate à mettre en forme — à froid pour le métal, à chaud avec une thermoplieuse pour le plastique.",
    cout:"Faible",coutDetail:"2 – 12 € / pièce",eco:4,ecoDetail:"Aucune matière perdue, procédé propre",
    phases:{prep:"10 min",fab:"5 – 20 min",finish:"5 min"},
    scores:{cout:5,temps:5,precision:3,eco:4},
    fichiers:{principaux:["DXF","DWG"],secondaires:["PDF","Plan papier"]},
    logiciels:[
      {nom:"LibreCAD",type:"free"},{nom:"FreeCAD",type:"free"},
      {nom:"SolidWorks",type:"payant"},{nom:"Onshape",type:"free"},
    ]
  },
  percage:{
    name:"Perçage",col:"#E67E22",sub:"Trous par enlèvement de matière",
    why:"Procédé complémentaire pour créer des trous précis dans ta pièce, quel que soit le matériau.",
    cout:"Très faible",coutDetail:"< 2 € / trou",eco:4,ecoDetail:"Consommation énergétique minimale",
    phases:{prep:"5 min",fab:"1 – 5 min",finish:"2 min"},
    scores:{cout:5,temps:5,precision:3,eco:4},
    fichiers:{principaux:["DXF","PDF"],secondaires:["Plan papier"]},
    logiciels:[
      {nom:"LibreCAD",type:"free"},{nom:"QCAD",type:"free"},
      {nom:"AutoCAD",type:"payant"},{nom:"Inkscape",type:"free"},
    ]
  },
};

const ECO_LABELS=["","Très polluant","Polluant","Moyen","Propre","Très propre"];
const TOTAL=6;
let cur=0,ans=new Array(TOTAL).fill(null),showComp=false;

function buildSteps(){
  const el=document.getElementById('steps');el.innerHTML='';
  for(let i=0;i<TOTAL;i++){
    const d=document.createElement('div');
    d.className='step-pip'+(i<cur?' done':i===cur?' active':'');
    el.appendChild(d);
  }
}

function render(){
  buildSteps();
  document.getElementById('loadZone').className='loading-zone';
  document.getElementById('resultZone').className='result-zone';
  document.getElementById('qZone').style.display='block';
  const q=QS[cur];
  document.getElementById('qZone').innerHTML=`
    <div class="q-eyebrow animate-in">${q.eye}</div>
    <div class="q-text animate-in" style="animation-delay:.04s">${q.txt}</div>
    <div class="choices ${q.cols} animate-in" id="choices" style="animation-delay:.08s"></div>
    <div class="nav animate-in" style="animation-delay:.12s">
      ${cur>0?'<button class="btn-back2" onclick="goBack()">← Retour</button>':''}
      <button class="btn-go" id="btnGo" onclick="goNext()" ${ans[cur]===null?'disabled':''}>
        ${cur===TOTAL-1?'Analyser ma pièce ⚙️':'Suivant →'}
      </button>
    </div>`;
  const grid=document.getElementById('choices');
  q.opts.forEach((o,i)=>{
    const btn=document.createElement('button');
    btn.className='choice-btn'+(ans[cur]===i?' selected':'');
    btn.style.setProperty('--sel',o.col);
    btn.innerHTML=`<span class="chk">✓</span><div class="ci">${o.icon}</div><div class="cm">${o.main}</div><div class="cs">${o.sub}</div><div class="c-stripe"></div>`;
    btn.onclick=()=>pick(i);
    grid.appendChild(btn);
  });
}

function pick(i){
  ans[cur]=i;
  document.querySelectorAll('.choice-btn').forEach((b,idx)=>{b.className='choice-btn'+(idx===i?' selected':'');});
  document.getElementById('btnGo').disabled=false;
}

function goNext(){
  if(ans[cur]===null)return;
  if(cur<TOTAL-1){cur++;render();}
  else{
    document.getElementById('qZone').style.display='none';
    document.getElementById('loadZone').className='loading-zone show';
    buildSteps();
    setTimeout(showResult,1800);
  }
}
function goBack(){if(cur>0){cur--;render();}}

function ecoBar(n){
  let h='';for(let i=1;i<=5;i++)h+=`<div class="eco-dot${i<=n?' fill':''}"></div>`;return h;
}
function scoreBar(v,c){
  return `<div class="bar-wrap"><div class="bar-fill" style="width:${Math.round(v/5*100)}%;background:${c}"></div></div>`;
}
function toggleCompare(){
  showComp=!showComp;
  document.getElementById('compareTable').className='compare-table'+(showComp?' show':'');
  document.getElementById('compareBtn').textContent=showComp?'▲ Masquer la comparaison':'▼ Pourquoi pas les autres ?';
}

function showResult(){
  document.getElementById('loadZone').className='loading-zone';
  const ranked=Object.entries((()=>{
    const s={laser:0,imp3d:0,cnc:0,cisaille:0,pliage:0,percage:0};
    const[type,mat,prec,qty,cplx,finish]=ans;
    if(type===0){s.laser+=5;s.cisaille+=3;s.pliage+=3;s.percage+=2}
    if(type===1){s.imp3d+=5;s.cnc+=4}
    if(mat===0){s.laser+=3;s.cisaille+=3;s.pliage+=3;s.cnc+=2}
    if(mat===1){s.laser+=3;s.cnc+=4;s.cisaille+=2}
    if(mat===2){s.laser+=2;s.imp3d+=5;s.cnc+=2;s.pliage+=2}
    if(prec===0){s.cisaille+=3;s.pliage+=3}
    if(prec===1){s.laser+=3;s.cnc+=3}
    if(prec===2){s.laser+=4;s.cnc+=2;s.imp3d+=1}
    if(qty===0){s.imp3d+=3;s.laser+=2;s.cnc+=2}
    if(qty===1){s.laser+=3;s.cnc+=2;s.imp3d+=2}
    if(qty===2){s.cisaille+=4;s.pliage+=4;s.laser+=2}
    if(cplx===0){s.cisaille+=4;s.pliage+=3;s.percage+=3}
    if(cplx===1){s.laser+=3;s.cnc+=3}
    if(cplx===2){s.laser+=4;s.imp3d+=3;s.cnc+=2}
    if(finish===0){s.cisaille+=2;s.pliage+=2;s.percage+=2}
    if(finish===1){s.laser+=2;s.cnc+=2;s.imp3d+=1}
    if(finish===2){s.cnc+=3;s.laser+=2;s.imp3d+=1}
    return s;
  })()).sort((a,b)=>b[1]-a[1]);

  const bestK=ranked[0][0];
  const alts=ranked.slice(1,3).map(r=>r[0]);
  const bp=PROCEDES[bestK];
  const crumbLabels=[
    ['Type',QS[0].opts[ans[0]].main],['Matière',QS[1].opts[ans[1]].main],
    ['Précision',QS[2].opts[ans[2]].main],['Qté',QS[3].opts[ans[3]].main],
    ['Complexité',QS[4].opts[ans[4]].main],['Finition',QS[5].opts[ans[5]].main],
  ];

  const tableRows=ranked.map(([k],i)=>{
    const p=PROCEDES[k];const isBest=i===0;
    return `<div class="ct-row${isBest?' best-row':''}">
      <div class="ct-name${isBest?' best':''}">${isBest?'★ ':''}${p.name}</div>
      <div class="ct-cell">${scoreBar(p.scores.cout,'#2A9D8F')}</div>
      <div class="ct-cell">${scoreBar(p.scores.temps,'#E76F51')}</div>
      <div class="ct-cell">${scoreBar(p.scores.precision,'#7E57C2')}</div>
      <div class="ct-cell">${scoreBar(p.scores.eco,'#5D9B6A')}</div>
    </div>`;
  }).join('');

  const softHTML=`
    <div class="soft-section">
      <div class="soft-section-title">Fichiers &amp; logiciels compatibles</div>
      <div class="soft-cols">
        <div>
          <div class="soft-col-label">Formats de fichiers</div>
          <div class="file-pills">
            ${bp.fichiers.principaux.map(f=>`<span class="file-pill main">.${f}</span>`).join('')}
            ${bp.fichiers.secondaires.map(f=>`<span class="file-pill">.${f}</span>`).join('')}
          </div>
          <div class="soft-col-label" style="margin-top:6px">Les .${bp.fichiers.principaux[0]} sont les plus courants</div>
        </div>
        <div>
          <div class="soft-col-label">Logiciels</div>
          <div class="soft-list">
            ${bp.logiciels.map(l=>`<div class="soft-item">
              <span class="soft-badge ${l.type}">${l.type==='free'?'Gratuit':'Payant'}</span>
              <span class="soft-name">${l.nom}</span>
            </div>`).join('')}
          </div>
        </div>
      </div>
    </div>`;

  const rz=document.getElementById('resultZone');
  rz.className='result-zone show';
  rz.innerHTML=`
    <div class="winner-card animate-in" style="background:${bp.col}">
      <div class="winner-tag">Meilleur procédé pour toi</div>
      <div class="winner-name">${bp.name}</div>
      <div class="winner-sub">${bp.sub}</div>
      <div class="winner-desc">${bp.why}</div>
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-label">Coût estimé</div>
          <div class="metric-val">${bp.cout}</div>
          <div class="metric-detail">${bp.coutDetail}</div>
        </div>
        <div class="metric-card">
          <div class="metric-label">Impact environnemental</div>
          <div class="metric-val">${ECO_LABELS[bp.eco]}</div>
          <div class="eco-bar">${ecoBar(bp.eco)}</div>
          <div class="metric-detail">${bp.ecoDetail}</div>
        </div>
      </div>
      <div class="phases-row">
        <div class="phase-box"><div class="phase-label">Préparation</div><div class="phase-val">${bp.phases.prep}</div></div>
        <div class="phase-box"><div class="phase-label">Fabrication</div><div class="phase-val">${bp.phases.fab}</div></div>
        <div class="phase-box"><div class="phase-label">Finition</div><div class="phase-val">${bp.phases.finish}</div></div>
      </div>
      ${softHTML}
      <button class="compare-btn" id="compareBtn" onclick="toggleCompare()">▼ Pourquoi pas les autres ?</button>
    </div>

    <div class="compare-table" id="compareTable">
      <div class="ct-head">
        <span>Procédé</span><span>Coût</span><span>Rapidité</span><span>Précision</span><span>Éco</span>
      </div>${tableRows}
    </div>

    <div class="alts-row animate-in" style="animation-delay:.1s">
      ${alts.map(k=>{const p=PROCEDES[k];return`<div class="alt-card">
        <div class="alt-tag">Alternative</div>
        <div class="alt-name">${p.name}</div>
        <div class="alt-chips">
          <span class="alt-chip">💶 ${p.cout}</span>
          <span class="alt-chip">🌿 ${ECO_LABELS[p.eco]}</span>
          <span class="alt-chip">⏱ ${p.phases.fab}</span>
          <span class="alt-chip">.${p.fichiers.principaux[0]}</span>
        </div>
      </div>`;}).join('')}
    </div>

    <div class="crumbs animate-in" style="animation-delay:.14s">
      ${crumbLabels.map(([k,v])=>`<span class="crumb"><strong>${k}</strong> ${v}</span>`).join('')}
    </div>
    <button class="btn-again animate-in" style="animation-delay:.18s" onclick="restart()">↺ Recommencer</button>
  `;
}

function restart(){cur=0;ans=new Array(TOTAL).fill(null);showComp=false;render();}
render();
</script>
