.phases-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-top:7px}
.phase-box{background:rgba(255,255,255,0.14);border-radius:9px;padding:0.5rem 0.6rem;border:1px solid rgba(255,255,255,0.18);text-align:center}
.phase-label{font-size:0.57rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(255,255,255,0.5);margin-bottom:2px}
.phase-val{font-family:'Syne',sans-serif;font-size:0.88rem;font-weight:800;color:white}

.soft-section{margin-top:0.75rem;background:rgba(0,0,0,0.12);border-radius:12px;padding:0.7rem 0.8rem}
