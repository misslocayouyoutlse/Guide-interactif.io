.steps{display:flex;gap:5px;align-items:center}
.step-pip{height:6px;border-radius:4px;background:#d8d3cc;transition:all 0.4s;width:26px}
.step-pip.done{background:#2A9D8F}
.step-pip.active{background:#E76F51;width:38px}

.q-zone{position:relative;z-index:2}
.q-eyebrow{font-size:0.67rem;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:#a09a90;margin-bottom:0.35rem}
.q-text{font-family:'Syne',sans-serif;font-size:1.15rem;font-weight:800;color:#1a1a2e;line-height:1.25;margin-bottom:1rem}
.choices{display:grid;gap:8px;position:relative;z-index:2}
.choices.two{grid-template-columns:1fr 1fr}
.choices.three{grid-template-columns:1fr 1fr 1fr}
.choice-btn{border:2px solid #e8e3dc;cursor:pointer;border-radius:14px;padding:0.85rem 0.75rem;text-align:left;display:flex;flex-direction:column;gap:3px;transition:transform 0.18s,box-shadow 0.18s,border-color 0.18s;font-family:'DM Sans',sans-serif;position:relative;background:white}
.choice-btn:hover{transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,0.09)}
.choice-btn.selected{border-color:var(--sel);transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,0.11)}
.choice-btn.selected .chk{opacity:1}
.chk{position:absolute;top:7px;right:8px;width:20px;height:20px;border-radius:50%;background:var(--sel,#E76F51);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:800;color:white;opacity:0;transition:opacity 0.2s}
.c-stripe{position:absolute;bottom:0;left:0;right:0;height:4px;border-radius:0 0 12px 12px;background:var(--sel,#ccc);opacity:0;transition:opacity 0.2s}
.choice-btn.selected .c-stripe{opacity:1}
.ci{font-size:1.4rem;line-height:1;margin-bottom:3px}
.cm{font-size:0.85rem;font-weight:700;color:#1a1a2e;line-height:1.2}
.cs{font-size:0.68rem;color:#9a9490;font-weight:500}

.nav{display:flex;gap:8px;margin-top:0.9rem;position:relative;z-index:2}
.btn-back2{background:white;border:1.5px solid #d8d3cc;color:#6a6460;font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.83rem;padding:0.62rem 0.9rem;border-radius:11px;cursor:pointer;transition:all 0.2s;flex-shrink:0}
.btn-back2:hover{background:#f5f0eb}
.btn-go{flex:1;background:#E76F51;border:none;color:white;font-family:'Syne',sans-serif;font-weight:800;font-size:0.92rem;padding:0.72rem;border-radius:11px;cursor:pointer;transition:all 0.2s}
.btn-go:hover:not(:disabled){background:#d4603f;transform:translateY(-2px);box-shadow:0 6px 16px rgba(231,111,81,0.32)}
.btn-go:disabled{background:#ddd;color:#aaa;cursor:not-allowed;transform:none;box-shadow:none}

.loading-zone{display:none;position:relative;z-index:2;text-align:center;padding:2.5rem 0}
.loading-zone.show{display:block}
.machine-anim{font-size:3rem;animation:spin 0.7s linear infinite;display:inline-block;margin-bottom:0.6rem}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
.loading-txt{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:#1a1a2e;margin-bottom:0.3rem}
.loading-sub{font-size:0.78rem;color:#9a9490;font-weight:500}
.dots-anim::after{content:'';animation:dots 1.2s steps(3,end) infinite}
@keyframes dots{0%{content:''}33%{content:'.'}66%{content:'..'}100%{content:'...'}}

.result-zone{position:relative;z-index:2;display:none}
.result-zone.show{display:block}

.winner-card{border-radius:18px;padding:1.1rem 1rem;margin-bottom:0.7rem;position:relative;overflow:hidden}
.winner-tag{font-size:0.6rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:3px}
.winner-name{font-family:'Syne',sans-serif;font-size:1.35rem;font-weight:800;color:white;line-height:1}
.winner-sub{font-size:0.75rem;color:rgba(255,255,255,0.7);margin-top:3px;font-weight:500}
