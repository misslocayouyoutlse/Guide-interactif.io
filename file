.metric-val{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:white;line-height:1}
.metric-detail{font-size:0.66rem;color:rgba(255,255,255,0.6);margin-top:3px;font-weight:500;line-height:1.4}
.eco-bar{display:flex;gap:3px;margin-top:4px}
.eco-dot{width:13px;height:7px;border-radius:2px;background:rgba(255,255,255,0.2)}
