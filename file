.file-pill.main{background:rgba(255,255,255,0.32);border-color:rgba(255,255,255,0.5)}
.soft-list{display:flex;flex-direction:column;gap:4px}
.soft-item{display:flex;align-items:center;gap:6px}
.soft-badge{border-radius:6px;padding:2px 7px;font-size:0.65rem;font-weight:700;color:white;flex-shrink:0}
.soft-badge.free{background:rgba(42,157,143,0.8)}
.soft-badge.payant{background:rgba(231,111,81,0.7)}
